{
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ES2024",
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "types": [
      "node"
    ],
    "lib": [
      "ES2024"
    ],
    "module": "NodeNext",
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true
  },
  "exclude": [
    "dist",
    "bin/**/*",
    "test/**/*",
    "vitest.config.*",
    "node_modules"
  ]
}
